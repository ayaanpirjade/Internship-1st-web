<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>AYAAN Weather | OpenWeatherMap</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, 'Roboto', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(145deg, #0b2b44 0%, #123e5e 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            position: relative;
        }

        /* Main card */
        .weather-card {
            max-width: 580px;
            width: 100%;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            border-radius: 2.5rem;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.2);
            overflow: hidden;
            transition: all 0.3s ease;
            padding: 1.8rem 2rem 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
            color: white;
            text-align: center;
            letter-spacing: -0.3px;
            text-shadow: 0 2px 5px rgba(0,0,0,0.2);
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .brand {
            text-align: center;
            margin-bottom: 0.8rem;
        }
        
        .brand-name {
            font-size: 0.9rem;
            font-weight: 500;
            background: linear-gradient(135deg, #FFD700, #FFA500);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            letter-spacing: 0.5px;
        }
        
        .brand-handle {
            font-size: 0.75rem;
            color: #ffd966;
            opacity: 0.9;
            margin-left: 5px;
        }
        
        .github-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(0,0,0,0.4);
            padding: 4px 12px;
            border-radius: 40px;
            text-decoration: none;
            color: #e0e0e0;
            font-size: 0.75rem;
            transition: all 0.2s;
            margin-top: 5px;
        }
        
        .github-link:hover {
            background: rgba(0,0,0,0.6);
            color: white;
            transform: translateY(-1px);
        }

        .sub {
            text-align: center;
            color: #d9eaff;
            font-size: 0.75rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px dashed rgba(255,255,255,0.2);
            display: inline-block;
            width: auto;
            padding-bottom: 6px;
        }

        /* search area */
        .search-section {
            display: flex;
            gap: 12px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }
        .search-input {
            flex: 1;
            padding: 14px 18px;
            border: none;
            border-radius: 60px;
            font-size: 1rem;
            background: rgba(255, 255, 255, 0.95);
            outline: none;
            transition: all 0.2s;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            font-weight: 500;
        }
        .search-input:focus {
            background: white;
            box-shadow: 0 0 0 3px rgba(255,215,0,0.5);
        }
        .search-btn {
            background: #ffb347;
            background: linear-gradient(135deg, #ffb347, #ff8c00);
            border: none;
            padding: 0 28px;
            border-radius: 60px;
            font-weight: bold;
            font-size: 1rem;
            color: white;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 6px 12px rgba(0,0,0,0.2);
            letter-spacing: 0.5px;
        }
        .search-btn:hover {
            transform: scale(0.97);
            background: linear-gradient(135deg, #ffa01e, #f57c00);
            box-shadow: 0 3px 8px rgba(0,0,0,0.3);
        }
        .search-btn:active {
            transform: scale(0.95);
        }
        
        /* location button */
        .geo-btn {
            background: #2c5f8a;
            border: none;
            border-radius: 60px;
            width: 52px;
            font-size: 1.4rem;
            cursor: pointer;
            color: white;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            transition: all 0.2s;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .geo-btn:hover {
            background: #1f4a6e;
            transform: scale(0.97);
        }

        /* weather main display */
        .weather-info {
            text-align: center;
            color: white;
            transition: all 0.25s;
        }
        .city-name {
            font-size: 2.2rem;
            font-weight: 700;
            margin-top: 0.5rem;
            margin-bottom: 0.2rem;
            text-shadow: 0 2px 5px rgba(0,0,0,0.3);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .country {
            font-size: 1.1rem;
            background: rgba(0,0,0,0.3);
            padding: 4px 12px;
            border-radius: 40px;
            font-weight: 500;
        }
        .temp {
            font-size: 4.5rem;
            font-weight: 800;
            margin: 0.5rem 0;
            letter-spacing: -2px;
            line-height: 1;
            display: inline-flex;
            align-items: baseline;
        }
        .temp-unit {
            font-size: 1.8rem;
            font-weight: 500;
            margin-left: 5px;
        }
        .weather-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto;
            filter: drop-shadow(0 6px 12px rgba(0,0,0,0.3));
        }
        .description {
            font-size: 1.25rem;
            text-transform: capitalize;
            font-weight: 500;
            background: rgba(0,0,0,0.25);
            display: inline-block;
            padding: 6px 18px;
            border-radius: 40px;
            margin-top: 8px;
            backdrop-filter: blur(4px);
        }
        .details {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            margin-top: 28px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 2rem;
            padding: 1rem 1.6rem;
            flex-wrap: wrap;
        }
        .detail-item {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .detail-item span:first-child {
            font-weight: 400;
            opacity: 0.8;
        }
        .detail-item span:last-child {
            font-weight: 700;
        }

        /* error & loading */
        .error-message {
            background: #d32f2fdd;
            backdrop-filter: blur(8px);
            padding: 12px;
            border-radius: 50px;
            margin-top: 20px;
            font-weight: 500;
            text-align: center;
            color: white;
        }
        .loading {
            display: inline-block;
            margin-top: 20px;
            font-size: 1rem;
            background: rgba(255,255,240,0.2);
            padding: 8px 20px;
            border-radius: 40px;
        }
        .hidden {
            display: none;
        }
        
        /* footer with branding */
        .footer-brand {
            margin-top: 28px;
            text-align: center;
            border-top: 1px solid rgba(255,255,255,0.2);
            padding-top: 16px;
        }
        
        .credit {
            font-size: 0.75rem;
            color: #cce7f5;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        
        .credit strong {
            color: #FFD966;
            font-weight: 600;
        }
        
        .iowncodz {
            background: rgba(0,0,0,0.3);
            padding: 3px 10px;
            border-radius: 30px;
            font-family: monospace;
            letter-spacing: 0.5px;
        }
        
        .github-footer {
            color: #ffd966;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: 0.2s;
        }
        
        .github-footer:hover {
            color: white;
            text-shadow: 0 0 3px rgba(255,215,0,0.5);
        }
        
        hr {
            margin: 8px 0;
            border-color: rgba(255,255,255,0.1);
        }
        
        @media (max-width: 480px) {
            .weather-card {
                padding: 1.2rem;
            }
            .temp {
                font-size: 3.2rem;
            }
            .city-name {
                font-size: 1.6rem;
            }
            .details {
                flex-direction: column;
                align-items: stretch;
                gap: 12px;
            }
            .credit {
                flex-direction: column;
                gap: 5px;
            }
        }
    </style>
</head>
<body>

<div class="weather-card">
    <div class="brand">
        <h1>
            <span>⛅</span> AYAAN Weather
        </h1>
        <div class="brand-name">
            ✨ made by AYAAN <span class="brand-handle">@IOWNCODZ</span>
            <a href="https://github.com/ayaanpirjade" target="_blank" class="github-link" style="margin-left: 8px;">
                <span>🐙</span> github.com/ayaanpirjade
            </a>
        </div>
        <div style="text-align: center; margin-top: 4px;">
            <span class="sub">powered by OpenWeatherMap • real-time forecasts</span>
        </div>
    </div>

    <!-- Search Area -->
    <div class="search-section">
        <input type="text" id="cityInput" class="search-input" placeholder="Enter city name, e.g., London, Tokyo, New York" autocomplete="off">
        <button id="searchBtn" class="search-btn">🔍 Search</button>
        <button id="geoBtn" class="geo-btn" title="Use my current location">📍</button>
    </div>

    <!-- Weather dynamic container -->
    <div id="weatherContainer" class="weather-info">
        <!-- welcome message with AYAAN touch -->
        <div style="margin: 20px 0; opacity: 0.95;">
            <div style="font-size: 4rem;">🌤️</div>
            <p style="font-size: 1.1rem; margin-top: 8px;">Hey <strong style="color:#FFD966;">AYAAN</strong> — search any city to see live weather!</p>
            <p style="font-size: 0.85rem; margin-top: 12px;">✨ Try: Paris, Mumbai, Sydney, Rio, Tokyo</p>
            <p style="font-size: 0.7rem; margin-top: 8px;">📍 or click location button for your local weather</p>
        </div>
    </div>

    <!-- Footer branding + github -->
    <div class="footer-brand">
        <div class="credit">
            <span>⚡ <strong>AYAAN</strong> <span style="font-family: monospace;">@IOWNCODZ</span></span>
            <span>•</span>
            <a href="https://github.com/ayaanpirjade" target="_blank" class="github-footer">
                🐙 GitHub: ayaanpirjade
            </a>
            <span>•</span>
            <span>🌍 OpenWeather API</span>
        </div>
        <hr>
        <div style="font-size: 0.7rem; opacity: 0.7; margin-top: 6px;">
            built with 💙 by AYAAN | real-time weather data
        </div>
    </div>
</div>

<script>
    const API_KEY = '50616fee2e17d99aa1daa836a9ad16ac';   // <-- REPLACE WITH YOUR ACTUAL API KEY
    
    const BASE_URL = 'https://api.openweathermap.org/data/2.5/weather';
    
    // DOM elements
    const cityInput = document.getElementById('cityInput');
    const searchBtn = document.getElementById('searchBtn');
    const geoBtn = document.getElementById('geoBtn');
    const weatherContainer = document.getElementById('weatherContainer');
    
    // Helper UI
    function showLoading() {
        weatherContainer.innerHTML = `
            <div class="loading">
                <span>🌀</span> Fetching weather data for you, AYAAN...
            </div>
        `;
    }
    
    function showError(message) {
        weatherContainer.innerHTML = `
            <div class="error-message">
                ⚠️ ${message}
            </div>
            <div style="margin-top: 16px; font-size:0.85rem; opacity:0.9;">
                💡 Tip: Check city name or use location button, AYAAN.
            </div>
        `;
    }
    
    function kelvinToCelsius(kelvin) {
        return (kelvin - 273.15).toFixed(1);
    }
    
    function getWeatherIconUrl(iconCode) {
        return `https://openweathermap.org/img/wn/${iconCode}@2x.png`;
    }
    
    function formatWindSpeed(speedMps) {
        return `${speedMps.toFixed(1)} m/s`;
    }
    
    function capitalize(str) {
        return str.charAt(0).toUpperCase() + str.slice(1);
    }
    
    // core fetch by city name
    async function fetchWeather(city) {
        if (!city || city.trim() === "") {
            showError("Please enter a city name.");
            return;
        }
        
        const cityEncoded = encodeURIComponent(city.trim());
        const url = `${BASE_URL}?q=${cityEncoded}&appid=${API_KEY}`;
        showLoading();
        
        try {
            const response = await fetch(url);
            const data = await response.json();
            
            if (!response.ok) {
                if (response.status === 404) {
                    showError(`City "${city}" not found. Try another city, AYAAN.`);
                } else if (response.status === 401) {
                    showError("Invalid API key. Please replace 'YOUR_API_KEY' with your OpenWeatherMap key.");
                } else {
                    showError(`Error ${response.status}: ${data.message || "Something went wrong"}`);
                }
                return;
            }
            
            // success render
            renderWeatherData(data, "search");
            if (data.name) cityInput.value = data.name;
        } catch (error) {
            console.error("Fetch error:", error);
            showError("Network error. Check your connection and try again.");
        }
    }
    
    // unified render function
    function renderWeatherData(data, source = "search") {
        const cityName = data.name;
        const country = data.sys.country;
        const tempKelvin = data.main.temp;
        const tempCelsius = kelvinToCelsius(tempKelvin);
        const feelsLikeKelvin = data.main.feels_like;
        const feelsLikeCelsius = kelvinToCelsius(feelsLikeKelvin);
        const humidity = data.main.humidity;
        const windSpeed = data.wind.speed;
        const pressure = data.main.pressure;
        const weatherDescription = data.weather[0].description;
        const iconCode = data.weather[0].icon;
        const weatherMain = data.weather[0].main;
        const visibility = data.visibility ? (data.visibility / 1000).toFixed(1) : null;
        
        const sourceBadge = source === "geo" ? '<span style="font-size:0.7rem; background:#ffffff30; border-radius:20px; padding:2px 8px;">📍 Live location</span>' : '';
        
        const weatherHTML = `
            <div class="city-name">
                <span>📍 ${cityName}</span>
                <span class="country">${country}</span>
                ${sourceBadge}
            </div>
            <div class="temp">
                ${tempCelsius}<span class="temp-unit">°C</span>
            </div>
            <div>
                <img class="weather-icon" src="${getWeatherIconUrl(iconCode)}" alt="${weatherDescription}">
            </div>
            <div class="description">
                ${capitalize(weatherDescription)} 
                <span style="font-size:0.8rem;"> (${weatherMain})</span>
            </div>
            
            <div class="details">
                <div class="detail-item">
                    <span>🌡️ Feels like</span>
                    <span>${feelsLikeCelsius}°C</span>
                </div>
                <div class="detail-item">
                    <span>💧 Humidity</span>
                    <span>${humidity}%</span>
                </div>
                <div class="detail-item">
                    <span>🌬️ Wind</span>
                    <span>${formatWindSpeed(windSpeed)}</span>
                </div>
                <div class="detail-item">
                    <span>🔽 Pressure</span>
                    <span>${pressure} hPa</span>
                </div>
                ${visibility ? `<div class="detail-item"><span>👁️ Visibility</span><span>${visibility} km</span></div>` : ''}
            </div>
            <div style="margin-top: 12px; font-size:0.7rem; opacity:0.7;">
                🕒 updated: ${new Date().toLocaleTimeString()} • AYAAN weather
            </div>
        `;
        weatherContainer.innerHTML = weatherHTML;
    }
    
    // geolocation weather fetch
    async function fetchWeatherByCoords(lat, lon) {
        const geoUrl = `${BASE_URL}?lat=${lat}&lon=${lon}&appid=${API_KEY}`;
        try {
            const response = await fetch(geoUrl);
            const data = await response.json();
            if (!response.ok) {
                showError(`Location error: ${data.message || "Could not fetch weather"}`);
                return;
            }
            renderWeatherData(data, "geo");
            if (data.name) cityInput.value = data.name;
        } catch (err) {
            showError("Failed to get weather from your location. Try searching manually.");
        }
    }
    
    function handleGeolocation() {
        if (API_KEY === 'YOUR_API_KEY') {
            showError("🔐 Please set a valid OpenWeatherMap API key first. Replace 'YOUR_API_KEY' in code.");
            return;
        }
        if (!navigator.geolocation) {
            showError("Geolocation is not supported by your browser.");
            return;
        }
        showLoading();
        navigator.geolocation.getCurrentPosition(
            (position) => {
                const lat = position.coords.latitude;
                const lon = position.coords.longitude;
                fetchWeatherByCoords(lat, lon);
            },
            (err) => {
                let errorMsg = "Location access denied or unavailable.";
                if (err.code === 1) errorMsg = "⚠️ Permission denied. Allow location to use this feature, AYAAN.";
                else if (err.code === 2) errorMsg = "Position unavailable. Try searching city manually.";
                showError(errorMsg);
            }
        );
    }
    
    // safe search with API key check
    function safePerformSearch() {
        if (API_KEY === 'YOUR_API_KEY') {
            showError("🔐 API Key Missing! Please replace 'YOUR_API_KEY' with your OpenWeatherMap API key (get free at openweathermap.org).");
            return;
        }
        const city = cityInput.value.trim();
        if (city === "") {
            showError("Please type a city name before searching, AYAAN!");
            return;
        }
        fetchWeather(city);
    }
    
    // function to check API key on load and show personalized message
    function checkApiKeyAndSetup() {
        if (API_KEY === 'YOUR_API_KEY') {
            weatherContainer.innerHTML = `
                <div class="error-message" style="background: #ff9800cc;">
                    ⚠️ API Key Required — Hello AYAAN!
                </div>
                <div style="margin-top: 16px; background: rgba(0,0,0,0.5); border-radius: 20px; padding: 14px; font-size:0.9rem;">
                    <strong>🔑 Setup guide for @IOWNCODZ:</strong><br>
                    1. Get a free API key from <a href="https://openweathermap.org/api" target="_blank" style="color: #ffd966;">OpenWeatherMap</a><br>
                    2. Replace <code style="background:black;padding:2px 6px;border-radius:8px;">'YOUR_API_KEY'</code> with your actual key.<br>
                    <span style="font-size:0.8rem;">✨ After adding key, refresh & search any city to see live weather.</span>
                    <hr style="margin: 10px 0;">
                    <div style="font-size:0.75rem;">🌟 Made by AYAAN @IOWNCODZ — once API key is set, weather will show instantly.</div>
                </div>
            `;
            return false;
        }
        return true;
    }
    
    // Event binding
    searchBtn.addEventListener('click', safePerformSearch);
    cityInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            safePerformSearch();
        }
    });
    geoBtn.addEventListener('click', () => {
        if (API_KEY === 'YOUR_API_KEY') {
            showError("🔐 Please configure your OpenWeatherMap API key first (replace 'YOUR_API_KEY') to use location feature.");
            return;
        }
        handleGeolocation();
    });
    
    // Initialize
    window.addEventListener('DOMContentLoaded', () => {
        const keyValid = checkApiKeyAndSetup();
        if (keyValid) {
            // Show a nice branding greeting with AYAAN touch
            weatherContainer.innerHTML = `
                <div style="margin: 20px 0;">
                    <div style="font-size: 3.8rem;">☁️✨</div>
                    <p style="margin-top: 8px; font-weight:500;">Welcome back, <strong style="color:#FFD966;">AYAAN @IOWNCODZ</strong>!</p>
                    <p style="font-size:0.9rem;">Search any city or use <strong>📍 location</strong> button for live weather.</p>
                    <p style="font-size:0.75rem; margin-top: 12px; background: #00000040; display: inline-block; padding: 4px 12px; border-radius: 30px;">⚡ real-time data from OpenWeatherMap</p>
                </div>
            `;
        }
    });
    
    // Optional console branding
    console.log("%c✨ AYAAN Weather App | @IOWNCODZ ✨", "color: #ffb347; font-size: 16px; font-weight: bold;");
    console.log("%cGitHub: https://github.com/IOWNCODZ | Weather by OpenWeatherMap", "color: #88c0ff; font-size: 12px;");
</script>
</body>
</html>